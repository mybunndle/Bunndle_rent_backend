model Asset {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  userId           String    @db.ObjectId
  user             User      @relation(fields: [userId], references: [id])

  model            String
  brand            String
  price            String?
  assetName        String?
  category         String
  subCategory      String?
  purchaseYear     String

  isapproved       AssetApprovalStatus @default(pending)

  deleteRequest    Boolean   @default(false)
  deleteRequestAt  DateTime?

  files            AssetFile[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@map("assets")
}

type AssetFile {
  url      String
  filename String
  fileId   String
}

enum AssetApprovalStatus {
  approved
  rejected
  pending
  approvedButNotInApp
}